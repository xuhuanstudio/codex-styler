{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Styler",
  "version": "0.1.0-alpha.1",
  "identifier": "studio.xuhuan.codexstyler",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Styler",
        "width": 1320,
        "height": 840,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#E8E9E4"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:*; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Themes and interactive scenes for Codex Desktop",
    "longDescription": "An unofficial, open-source, local-first theme and interactive scene editor for OpenAI Codex Desktop.",
    "copyright": "Copyright 2026 Codex Styler contributors",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "wix": {
        "language": ["en-US", "zh-CN"]
      },
      "nsis": {
        "languages": ["English", "SimpChinese"]
      }
    }
  }
}

