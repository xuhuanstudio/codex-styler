{
  "name": "@codex-styler/theme-core",
  "version": "0.2.0-beta.6",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./schema/theme.schema.json",
    "./companion-schema": "./schema/companion.schema.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "node scripts/generate-validator.mjs --check && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate:validator": "node scripts/generate-validator.mjs",
    "theme:validate": "tsx src/cli.ts",
    "package:validate": "tsx src/cli.ts"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
